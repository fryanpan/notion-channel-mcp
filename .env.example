# Copy this file to .env and fill in the real values.

# Notion integration token (from https://www.notion.so/my-integrations → "Internal Integration Secret").
# Required by both the receiver daemon and the MCP server (if it ever needs to fetch Notion state directly).
NOTION_INTEGRATION_TOKEN=secret_...

# Shown once when you create the webhook subscription in the Notion UI. Not used for signature
# verification yet; stored for future hardening.
NOTION_WEBHOOK_SECRET=

# Local HTTP port the receiver listens on. The Cloudflare Tunnel should point at this port.
NOTION_RECEIVER_PORT=8787

# Override the SQLite subscription store path. Default: ~/.notion-channel.db
# NOTION_CHANNEL_DB=/Users/me/.notion-channel.db

# Override the claude-hive broker URL. Default: http://127.0.0.1:7900
# CLAUDE_HIVE_URL=http://127.0.0.1:7900
